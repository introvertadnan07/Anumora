<% layout("layouts/boilerplate") -%>

<div class="row mt-4">
  <div class="col-md-6 mx-auto">

    <h3 class="mb-4 text-center">Payment 💳</h3>

    <div class="card shadow-sm mb-3">
      <img
        src="<%= booking.listing.image?.url || 'https://via.placeholder.com/800x400?text=No+Image' %>"
        class="card-img-top"
        style="height: 200px; object-fit: cover;"
      />

      <div class="card-body">
        <h5><%= booking.listing.title %></h5>

        <p class="mb-1">
          <strong>Check-In:</strong>
          <%= booking.checkIn.toDateString() %>
        </p>

        <p class="mb-1">
          <strong>Check-Out:</strong>
          <%= booking.checkOut.toDateString() %>
        </p>

        <p>
          <strong>Guests:</strong> <%= booking.guests %>
        </p>
      </div>
    </div>

    <form method="POST" action="/listings/<%= booking.listing._id %>/bookings/<%= booking._id %>/pay">
      <button class="btn btn-danger w-100">
        Pay Now
      </button>
    </form>

  </div>
</div>