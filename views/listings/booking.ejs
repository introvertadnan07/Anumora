<% layout("layouts/boilerplate") %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
.booking-wrap { max-width: 520px; margin: 0 auto; padding-bottom: 40px; }
.booking-card {
  background: white; border-radius: 18px;
  border: 1.5px solid #EBEBEB; box-shadow: 0 4px 24px rgba(0,0,0,0.09);
  overflow: hidden;
}
.booking-card-header {
  background: linear-gradient(135deg, #FF385C, #FF6B81);
  padding: 24px 28px; color: white;
}
.booking-card-header h3 { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
.booking-card-header p { font-size: 13.5px; opacity: 0.88; }
.price-tag { font-size: 22px; font-weight: 700; margin-top: 10px; }
.price-tag span { font-size: 14px; font-weight: 400; opacity: 0.8; }

.booking-body { padding: 26px 28px; }
.form-grp { margin-bottom: 18px; }
.form-lbl { font-size: 12.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #717171; display: block; margin-bottom: 7px; }
.form-inp {
  width: 100%; padding: 12px 14px;
  border: 1.5px solid #EBEBEB; border-radius: 10px;
  font-size: 14px; font-family: inherit; color: #222;
  background: #FAFAFA; outline: none;
  transition: border-color 0.18s, background 0.18s;
  cursor: pointer;
}
.form-inp:focus { border-color: #222; background: white; }
.dates-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

/* Price breakdown */
.price-breakdown {
  background: #F7F7F7; border-radius: 12px;
  padding: 16px 18px; margin: 20px 0;
  font-size: 14px;
}
.price-row { display: flex; justify-content: space-between; padding: 5px 0; color: #444; }
.price-row.total { font-weight: 700; color: #222; border-top: 1.5px solid #EBEBEB; margin-top: 8px; padding-top: 12px; font-size: 15px; }
.price-row.hidden { display: none; }

.book-btn {
  width: 100%; padding: 14px;
  background: #FF385C; color: white; border: none;
  border-radius: 12px; font-size: 15px; font-weight: 700;
  cursor: pointer; transition: background 0.18s;
  font-family: inherit;
}
.book-btn:hover { background: #e00b2f; }

.listing-mini-card {
  display: flex; align-items: center; gap: 14px;
  margin-bottom: 24px; padding-bottom: 20px;
  border-bottom: 1.5px solid #EBEBEB;
}
.listing-mini-img {
  width: 68px; height: 68px; border-radius: 10px;
  object-fit: cover; flex-shrink: 0;
  background: #FFE4E8;
}
.listing-mini-info .title { font-size: 14.5px; font-weight: 700; }
.listing-mini-info .loc { font-size: 13px; color: #717171; margin-top: 3px; }

/* Flatpickr overrides */
.flatpickr-day.booked {
  background: #FFE4E8 !important;
  color: #FF385C !important;
  text-decoration: line-through;
  cursor: not-allowed !important;
  pointer-events: none;
}
.flatpickr-day.selected { background: #FF385C !important; border-color: #FF385C !important; }
.flatpickr-day.inRange { background: #FFE4E8 !important; border-color: transparent !important; }
</style>

<div class="booking-wrap">
  <div class="booking-card">
    <div class="booking-card-header">
      <h3><%= listing.title %></h3>
      <p><i class="fa-solid fa-location-dot" style="margin-right:5px"></i><%= listing.location %>, <%= listing.country %></p>
      <div class="price-tag">₹<%= listing.price.toLocaleString("en-IN") %> <span>/ night</span></div>
    </div>

    <div class="booking-body">
      <!-- Listing mini card -->
      <div class="listing-mini-card">
        <% if (listing.image && listing.image.url) { %>
          <img src="<%= listing.image.url %>" class="listing-mini-img" alt="<%= listing.title %>">
        <% } else { %>
          <div class="listing-mini-img" style="display:flex;align-items:center;justify-content:center;font-size:28px">🏠</div>
        <% } %>
        <div class="listing-mini-info">
          <div class="title"><%= listing.title %></div>
          <div class="loc"><%= listing.location %>, <%= listing.country %></div>
        </div>
      </div>

      <form action="/listings/<%= listing._id %>/bookings" method="POST">

        <!-- ✅ Feature 8: Date pickers with booked dates blocked -->
        <div class="dates-row form-grp">
          <div>
            <label class="form-lbl">Check-In</label>
            <input type="text" id="checkIn" name="checkIn" class="form-inp" placeholder="Select date" required readonly>
          </div>
          <div>
            <label class="form-lbl">Check-Out</label>
            <input type="text" id="checkOut" name="checkOut" class="form-inp" placeholder="Select date" required readonly>
          </div>
        </div>

        <div class="form-grp">
          <label class="form-lbl">Guests</label>
          <input type="number" name="guests" class="form-inp" min="1" max="20" value="1" required>
        </div>

        <!-- Live price breakdown -->
        <div class="price-breakdown" id="priceBreakdown">
          <div class="price-row hidden" id="nightsRow">
            <span id="nightsLabel">— nights</span>
            <span id="nightsAmt">₹0</span>
          </div>
          <div class="price-row hidden total" id="totalRow">
            <span>Total</span>
            <span id="totalAmt">₹0</span>
          </div>
          <div id="selectPrompt" style="text-align:center;color:#B0B0B0;font-size:13px;padding:4px 0">
            Select dates to see price breakdown
          </div>
        </div>

        <button class="book-btn" type="submit">
          <i class="fa-regular fa-calendar-check" style="margin-right:8px"></i>Reserve Now
        </button>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
  const pricePerNight = <%= listing.price %>;

  // ✅ Build disabled dates from booked ranges
  const bookedRanges = <%- JSON.stringify(bookedRanges) %>;

  function getDisabledDates() {
    const disabled = [];
    bookedRanges.forEach(range => {
      const start = new Date(range.start);
      const end = new Date(range.end);
      // Add every date in the range
      const current = new Date(start);
      while (current <= end) {
        disabled.push(current.toISOString().split("T")[0]);
        current.setDate(current.getDate() + 1);
      }
    });
    return disabled;
  }

  const disabledDates = getDisabledDates();

  const checkInPicker = flatpickr("#checkIn", {
    minDate: "today",
    disable: disabledDates,
    dateFormat: "Y-m-d",
    disableMobile: true,
    onChange: function(selectedDates) {
      if (selectedDates[0]) {
        // Set checkout min date to day after checkin
        const nextDay = new Date(selectedDates[0]);
        nextDay.setDate(nextDay.getDate() + 1);
        checkOutPicker.set("minDate", nextDay);
      }
      updatePrice();
    },
    onDayCreate: function(dObj, dStr, fp, dayElem) {
      const dateStr = dayElem.dateObj.toISOString().split("T")[0];
      if (disabledDates.includes(dateStr)) {
        dayElem.classList.add("booked");
        dayElem.title = "Already booked";
      }
    }
  });

  const checkOutPicker = flatpickr("#checkOut", {
    minDate: "today",
    disable: disabledDates,
    dateFormat: "Y-m-d",
    disableMobile: true,
    onChange: function() { updatePrice(); },
    onDayCreate: function(dObj, dStr, fp, dayElem) {
      const dateStr = dayElem.dateObj.toISOString().split("T")[0];
      if (disabledDates.includes(dateStr)) {
        dayElem.classList.add("booked");
        dayElem.title = "Already booked";
      }
    }
  });

  function updatePrice() {
    const inVal = document.getElementById("checkIn").value;
    const outVal = document.getElementById("checkOut").value;

    if (!inVal || !outVal) return;

    const checkIn = new Date(inVal);
    const checkOut = new Date(outVal);
    const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));

    if (nights <= 0) return;

    const total = pricePerNight * nights;

    document.getElementById("nightsLabel").textContent = `₹${pricePerNight.toLocaleString("en-IN")} × ${nights} night${nights > 1 ? 's' : ''}`;
    document.getElementById("nightsAmt").textContent = `₹${total.toLocaleString("en-IN")}`;
    document.getElementById("totalAmt").textContent = `₹${total.toLocaleString("en-IN")}`;

    document.getElementById("nightsRow").classList.remove("hidden");
    document.getElementById("totalRow").classList.remove("hidden");
    document.getElementById("selectPrompt").style.display = "none";
  }
</script>
